      "type": "repeater",
      "layout": "row",
      "button_label": "Add Social Link",
      "sub_fields": [
        {
          "key": "field_luux_options_social_label",
          "label": "Label",
          "name": "label",
          "type": "text"
        },
        {
          "key": "field_luux_options_social_url",
          "label": "URL",
          "name": "url",
          "type": "text"
        },
        {
          "key": "field_luux_options_social_icon",
          "label": "Icon",
          "name": "icon",
